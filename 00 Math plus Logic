Pseudocode

while system_running:

    perception = observe_environment()
    model = predict_state()

    drift = model - perception
    stress = norm(drift)

    if stress < epsilon:
        decision = ACCEPT
    elif abs(derivative(stress)) < delta:
        decision = WAIT
    else:
        decision = REJECT

    state = update_state(state, decision, information, energy, resonance)

