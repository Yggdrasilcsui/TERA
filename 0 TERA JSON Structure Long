{
  "framework": {
    "id": "tera",
    "label": "TERA",
    "full_name": "Temporal Entropy & Resource Alignment",
    "version": "0.2.0",
    "status": "draft_public",
    "description": "Meta-level stability framework for evaluating whether informational representations of systems remain structurally stable under uncertainty, noise, drift, and contextual variation.",
    "audience": [
      "humans",
      "machines"
    ]
  },
  "design_principles": [
    {
      "id": "dp_001",
      "label": "Separation of identifier and meaning",
      "definition": "Stable identifiers must not depend on changing prose explanations."
    },
    {
      "id": "dp_002",
      "label": "Human-machine dual readability",
      "definition": "Every core element should be machine-addressable and human-readable."
    },
    {
      "id": "dp_003",
      "label": "Gate before commitment",
      "definition": "Representations must be evaluated before action, release, or strong coupling."
    }
  ],
  "entities": {
    "physical_state": {
      "id": "entity_physical_state",
      "symbol": "x_n",
      "label": "Physical state",
      "type": "state",
      "definition": "Underlying system state."
    },
    "observation": {
      "id": "entity_observation",
      "symbol": "y_n",
      "label": "Observation",
      "type": "measurement",
      "definition": "Measurement or observed output."
    },
    "control_input": {
      "id": "entity_control_input",
      "symbol": "u_n",
      "label": "Control input",
