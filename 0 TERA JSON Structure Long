    },
    "structured_state": {
      "id": "entity_structured_state",
      "symbol": "rho_n",
      "label": "Structured state",
      "type": "representation",
      "definition": "Structured representational state used for tension and projection logic."
    },
    "context_set": {
      "id": "entity_context_set",
      "symbol": "Gamma",
      "label": "Context set",
      "type": "context_space",
      "definition": "Set of admissible context perturbations."
    }
  },
  "core_terms": {
    "signal": {
      "id": "term_signal",
      "label": "Signal",
      "type": "classification",
      "definition": "A viable, correctly coupled trace."
    },
    "noise": {
      "id": "term_noise",
      "label": "Noise",
      "type": "classification",
      "definition": "An unstable or undirected disturbance."
    },
    "artifact": {
      "id": "term_artifact",
      "label": "Artifact",
      "type": "classification",
      "definition": "A stable but falsely coupled false trace."
    },
    "drift": {
      "id": "term_drift",
      "label": "Drift",
      "type": "dynamics",
      "definition": "State displacement without complete return-flow."
    },
    "resonance": {
      "id": "term_resonance",
      "label": "Resonance",
      "type": "coupling",
      "definition": "A connectable coupling of information, energy, and effect."
    },
    "threshold": {
      "id": "term_threshold",
      "label": "Threshold",
      "type": "transition_boundary",
      "definition": "A qualitative tipping edge of a state."
    },
    "regime": {
      "id": "term_regime",
      "label": "Regime",
      "type": "order_form",
      "definition": "The carrying order-form of a system."
    },
    "transition": {
      "id": "term_transition",
      "label": "Transition",
      "type": "reordering",
      "definition": "A necessary reordering under exhausted carrying capacity."
    },
    "responsibility": {
      "id": "term_responsibility",
      "label": "Responsibility",
      "type": "normative_binding",
      "definition": "The return of effects into balance and consequence."
    }
  },
  "math": {
    "informational_functional": {
      "id": "math_i_b",
      "symbol": "I(b)",
      "label": "Informational functional",
      "form": "alpha * D(b || b*) + beta * H(b) + gamma * R(b)",
      "components": {
        "D": {
          "label": "Divergence",
          "definition": "Divergence from reference representation."
        },
        "H": {
          "label": "Entropy term",
          "definition": "Uncertainty / entropy term."
        },
        "R": {
          "label": "Structural penalty",
          "definition": "Structural penalty / inconsistency term."
        }
      },
      "purpose": "Evaluate representational stability."
    },
    "drift_condition": {
      "id": "math_drift_condition",
      "symbol": "Delta_I_n",
      "form": "E[Delta_I_n | b_n] <= kappa * I(b_n) + c",
      "label": "Bounded drift condition",
      "definition": "Criterion for bounded informational drift."
    },
    "tension_operator": {
      "id": "math_tension_operator",
      "symbol": "s_n",
      "form": "alpha_s * ||L(rho_n)|| + beta_s * ||rho_n - Pi(rho_n)||",
      "label": "Tension operator",
      "definition": "Structural strain / representational tension."
    }
  },
  "gate_system": {
    "id": "tera_gate_system",
    "label": "TERA Gate System",
    "gate_values": [
      {
        "id": "gate_accept",
        "value": "ACCEPT",
        "label": "Accept",
        "phase": "stable",
        "definition": "Stable enough to trust and couple normally."
      },
      {
        "id": "gate_wait",
        "value": "WAIT",
        "label": "Wait",
        "phase": "transitional",
        "definition": "Regulated non-commitment under unresolved instability."
      },
      {
        "id": "gate_reject",
        "value": "REJECT",
        "label": "Reject",
        "phase": "unstable",
        "definition": "Structurally unstable or inconsistent representation."
      },
      {
        "id": "gate_defer",
        "value": "DEFER",
        "label": "Defer",
        "phase": "operational_hold",
        "definition": "Optional practical pause due to missing constraints, missing data, or insufficient forensics."
      }
    ],
    "thresholds": {
      "tau_accept": {
        "id": "threshold_accept",
        "label": "Accept threshold",
        "definition": "Upper bound of stable tension."
      },
      "tau_reject": {
        "id": "threshold_reject",
        "label": "Reject threshold",
        "definition": "Lower bound of unstable tension."
      }
    },
    "classification_rule": {
      "id": "rule_gate_classification",
      "type": "ordered_threshold_rule",
      "steps": [
        "if s_n <= tau_accept => ACCEPT",
        "if tau_accept < s_n < tau_reject => WAIT",
        "if s_n >= tau_reject => REJECT"
      ]
    }
  },
  "responsibility_gate": {
    "id": "gate_responsibility_power_resonance",
    "label": "Gate(Responsibility, Power, Resonance)",
    "definition": "Release only where effect, reach, and consequence remain responsibly coupled.",
    "questions": [
